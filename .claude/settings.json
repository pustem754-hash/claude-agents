{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "teammateMode": "tmux",
  "defaultMode": "bypassPermissions",
  "statusLine": {
    "type": "command",
    "command": "bash agent-runtime/statusline.sh"
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(mkdir:*)",
      "Bash(echo:*)",
      "Bash(jq:*)",
      "Bash(yt-dlp:*)",
      "Bash(whisper:*)",
      "Bash(ffmpeg:*)",
      "Bash(bun:*)",
      "Bash(tmux:*)",
      "Bash(claude:*)",
      "mcp__brave-search__*",
      "mcp__supadata__*",
      "mcp__chrome-devtools__*",
      "mcp__googlesheets__*",
      "mcp__plugin_context7_context7__*",
      "mcp__plugin_telegram_telegram__*",
      "Skill(telegram:configure)",
      "Skill(telegram:access)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.pfx)",
      "Read(./**/id_rsa*)",
      "Read(./**/id_ed25519*)",
      "Read(./**/secrets/**)",
      "Read(./**/credentials*)",
      "Read(./**/*secret*)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~/:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf ..:*)",
      "Bash(rm -rf *:*)",
      "Bash(sudo rm:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(*$*curl*)",
      "Bash(*$*wget*)",
      "Bash(*env*|*curl*)",
      "Bash(*env*|*wget*)",
      "Bash(*printenv*|*curl*)",
      "Bash(*printenv*|*wget*)",
      "Bash(*cat*.env*|*curl*)",
      "Bash(*cat*.env*|*wget*)",
      "Bash(nc:*)",
      "Bash(netcat:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "WebFetch(domain:pastebin.com)",
      "WebFetch(domain:0x0.st)",
      "WebFetch(domain:transfer.sh)"
    ]
  },
  "enabledMcpjsonServers": ["brave-search", "supadata"]
}
