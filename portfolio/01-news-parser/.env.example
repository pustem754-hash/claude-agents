RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# FlareSolverr (Docker-сервис для обхода JS-challenge)
# Поднимается через docker-compose up -d flaresolverr
FLARESOLVERR_URL=http://localhost:8191

# RU-прокси для сайтов за ServicePipe (tass.ru и т.п.)
# Формат: http://user:pass@host:port  или  socks5://host:port
# TASS_PROXY=

LOG_LEVEL=INFO
