# ─────────────────────────────────────────────────────────────
# bot/.env.example — шаблон. Скопируй в bot/.env и заполни.
# bot/.env в .gitignore (паттерн .env) — НИКОГДА не коммитится.
# config.py грузит сначала bot/.env, затем PROJECT_DIR/.env (fallback).
# ─────────────────────────────────────────────────────────────

# ── Telegram ────────────────────────────────────────────────
BOT_TOKEN=""

# ── Claude CLI (существующий путь генерации, claude_client.py) ─
CLAUDE_CLI="claude"
CLAUDE_MODEL="sonnet"
CLAUDE_TIMEOUT="1800"
CLAUDE_EXTRA_ARGS=""
SYSTEM_PROMPT_PATH=""
ADMIN_IDS=""
LOG_LEVEL="INFO"

# ── OpenRouter (новое — генерация SEO-контента) ─────────────
OPENROUTER_API_KEY=""
DEFAULT_SEO_MODEL=""
