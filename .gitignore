# ─────────────────────────────────────────────────────────────────────────────
# Secrets — NEVER commit
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ─────────────────────────────────────────────────────────────────────────────
# Claude Code local state
# ─────────────────────────────────────────────────────────────────────────────
.claude/settings.local.json
agent-runtime/outputs/
agent-runtime/state/

# ─────────────────────────────────────────────────────────────────────────────
# MCP local overrides (may contain secrets — prefer .mcp.json with ${ENV_VAR})
# ─────────────────────────────────────────────────────────────────────────────
.mcp.local.json

# ─────────────────────────────────────────────────────────────────────────────
# OS / editor
# ─────────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/

# ─────────────────────────────────────────────────────────────────────────────
# Python / Node
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
venv/
.venv/
node_modules/
dist/
build/

# ─────────────────────────────────────────────────────────────────────────────
# Skill install staging + backups (see agent-skills/INSTALL_MANIFEST.md)
# agent-skills/ itself IS tracked — it's the portable shared skill library
# ─────────────────────────────────────────────────────────────────────────────
tmp/
*.backup.*

# ─────────────────────────────────────────────────────────────────────────────
# Runtime noise / local artifacts (not for commit)
# ─────────────────────────────────────────────────────────────────────────────
