{
  "mcpServers": {
    "brave-search": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@brave/brave-search-mcp-server"
      ],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      }
    },
    "supadata": {
      "type": "http",
      "url": "https://api.supadata.ai/mcp",
      "headers": {
        "x-api-key": "${SUPADATA_API_KEY}"
      }
    },
    "agentmemory": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx -y @agentmemory/mcp"
      ],
      "env": {}
    },
    "figma-developer": {
      "type": "stdio",
      "command": "cmd",
      "args": [
        "/c",
        "npx -y figma-developer-mcp --figma-api-key=${FIGMA_API_KEY} --stdio"
      ],
      "env": {}
    }
  }
}